# Google Maps API keys — embedded into the native build by the react-native-maps
# Expo config plugin (see app.config.ts). These are NOT exposed in JS at runtime.
#
# Create keys at https://console.cloud.google.com/ and enable:
#   - Maps SDK for Android
#   - Maps SDK for iOS
#
# Restrict the Android key: Application restrictions → Android apps → your package name + SHA-1
# Restrict the iOS  key:    Application restrictions → iOS apps    → your bundle identifier
#
# Do NOT enable Places API, Directions API, or any other API on these keys.
# Do NOT use these keys server-side — create a separate server key for that.

EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=YOUR_ANDROID_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=YOUR_IOS_GOOGLE_MAPS_API_KEY
